---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
        title="Page not found | Veilkeeper"
        description="The page you were looking for could not be found."
>
    <section class="section">
        <div class="container">

            <div class="section-heading text-center">
                <h1>Page not found</h1>
                <p>
                    The veil shifted — the page you were looking for isn't here.
                    It may have moved, or the link may be out of date.
                </p>
            </div>

            <div class="actions" style="justify-content: center;">
                <a class="button button--primary" href="/">Back to the homepage</a>
                <a class="button button--secondary" href="/devlog/">Browse the devlog</a>
            </div>

        </div>
    </section>
</BaseLayout>
