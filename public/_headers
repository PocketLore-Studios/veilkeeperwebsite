# Interpreted by Cloudflare Workers static assets (Pages-style _headers file).
# https://developers.cloudflare.com/workers/static-assets/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Astro's content-hashed output — safe to cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Stable-but-unhashed filenames, occasionally edited in place
/assets/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# The five global stylesheets change without renaming — keep TTL short
/css/*
  Cache-Control: public, max-age=14400, stale-while-revalidate=86400

/favicon.png
  Cache-Control: public, max-age=86400
